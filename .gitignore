# SwiftPM build directory.
# Must be ignored — build.db (SQLite) can throw "disk I/O error" when the
# project path contains spaces (e.g. "MacOS Projects").
.build/
build/
dist/
*.app
*.dmg
DerivedData/
.DS_Store
# Claudemon.xcodeproj IS committed (canonical project — open THIS, not the
# folder). Ignore only the per-user state inside it and SwiftPM workspace cruft.
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
.swiftpm/
Package.resolved
.wrongstack/
